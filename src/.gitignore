# ============================================================
.vercel
.netlify
.serverless/
.amplify/
.firebase/
firebase-debug.log
firestore-debug.log


# ============================================================
# 🐳 Docker (الملفات المحلية بس)
# ============================================================
.docker/
docker-compose.override.yml


# ============================================================
