ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*


# ============================================================
# 💻 IDEs & Editors
# ============================================================

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (WebStorm, IntelliJ...)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim / Neovim
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# Emacs
\#*\#
.#*


