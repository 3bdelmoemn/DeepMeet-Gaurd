#======================== APP Info =========================#
APP_NAME="DeepMeet Guard"
APP_VERSION="1.0.0"
# ======================== storage Configuration ================#
SIMULATOR_STORAGE_PATH="assets/simulator_assets"
DETECTOR_STORAGE_PATH="assets/detector_assets"
#======================== LLM Configuration ================#

# Mode:
LLM_MODE="local"

# Base URLs:
OPEN_AI_BASE_URL="https://openrouter.ai/api/v1"
OLLAMA_BASE_URL="https://cola-underfoot-stony.ngrok-free.dev/"
GROQ_BASE_URL="http://localhost:8080/v1"

# Provider:
LLM_PROVIDER="gemini"

# API Keys:
OPENAI_API_KEY="xxx"
CLAUDE_API_KEY="xxx"
GEMINI_API_KEY="xxx"
COHERE_API_KEY="xxx"
OLLAMA_API_KEY="dammy"

#  Model IDs:

OPENAI_MODEL_ID="openai/gpt-4.1"
CLAUDE_MODEL_ID="claude-3-5-haiku-20241022"
GEMINI_MODEL_ID="gemini-2.5-flash"
COHERE_MODEL_ID="command-r-plus-08-2024"
OLLAMA_MODEL_ID="interview-assistant:latest"


# Model Parameters
MAX_TOKENS=1024
TEMPERATURE=0.1
CONTEXT_WINDOW=8192   
MAX_INPUT_TOKENS=6000

# History Management
HISTORY_MESSAGES=5
#======================== TTS Configuration ================#
TTS_BACKBONE="NANO_Q8"
TTS_CODEC="DISTILL_NEU_CODEC"
TTS_DEVICE="cpu"
TTS_CODEC_DEVICE="cpu"

TTS_STREAMING_OVERLAP_FRAMES = 0
TTS_STREAMING_FRAMES_PER_CHUNK = 50
TTS_STREAMING_LOOKFORWARD = 3
TTS_STREAMING_LOOKBACK = 70
TTS_FRAMES_PER_BUFFER = 32768
DEFAULT_REF_AUDIO_PATH="server/app_defaults/default_reference_audio_tts/dave.wav"
DEFAULT_REF_TEXT_PATH="server/app_defaults/default_reference_text_tts/dave.txt"
COOLDOWN_SECONDS=1.2
# ========================= STT Configuration ================#
STT_MODEL_PATH="server/infrastructure/stt/vosk-model-en-us-0.22"
MIN_WORDS=3
DEDUP_TTL=30.0
# ========================= Detection Configuration ================#

LAYER_ONE_WEIGHT=0.42
LAYER_TWO_WEIGHT=0.26
LAYER_THREE_WEIGHT=0.172
LAYER_FOUR_WEIGHT=0.148

LAYER_ONE_NAME="Spectra0"
LAYER_TWO_NAME="VIT"
LAYER_THREE_NAME="RawNet2"
LAYER_FOUR_NAME="liveness"

VIT_DATASET_NAME="VoxCelebSpoof"
VIT_VISIUALIZATION="ConstantQ"
LAYER_FOUR__MODELPATH="server/infrastructure/behaviour_liveness_detection_model"

